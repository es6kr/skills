#!/usr/bin/env sh

# Pre-push gate — mirrors the CI "Test" workflow (.github/workflows/test.yml)
# so failures are caught locally instead of only after push. The three checks
# below are 1:1 with the heavier CI jobs: frontmatter-lint, bats, pytest.
# The hangul-check CI job runs in pre-commit instead (see .githooks/pre-commit)
# so Korean text is rejected at commit time before the push attempt.
# Keep this in sync whenever a CI job is added/changed.

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# 'local' branch push guard — HARD STOP (double-defense with workspace rule
# 'agents-local-branch-nopush.md'). The 'local' branch is a user-private
# stage / working branch; pushing it to origin pollutes other environments
# and it is not a valid PR head (see git.md "PR head branch name convention").
# stdin is the pre-push protocol: `<local_ref> <local_sha> <remote_ref> <remote_sha>` lines.
LOCAL_PUSH_ATTEMPTED=0
LOCAL_STDIN=""
while IFS= read -r line; do
  LOCAL_STDIN="${LOCAL_STDIN}${line}
"
  # shellcheck disable=SC2086
  set -- $line
  local_ref="${1:-}"
  remote_ref="${3:-}"
  if [ "$local_ref" = "refs/heads/local" ] || [ "$remote_ref" = "refs/heads/local" ]; then
    LOCAL_PUSH_ATTEMPTED=1
  fi
done
if [ "$LOCAL_PUSH_ATTEMPTED" = "1" ] && [ "${PUSH_LOCAL_OVERRIDE:-}" != "1" ]; then
  cat >&2 <<'GUARD_MSG'
ERROR: Pushing the 'local' branch to origin is blocked.

'local' is a user-private stage branch. Push a feature branch + PR instead:
    git switch -c <tag>/<scope>      # <tag>=docs|fix|feat, <scope>=short slug
    git cherry-pick <sha>...          # bring the commits you want to publish
    git push -u origin <tag>/<scope>
    gh pr create -R es6kr/skills --title '...' --body '...'

Rule: .claude/rules/agents-local-branch-nopush.md

If you truly intend to force-push 'local' (rare, requires explicit user consent):
    PUSH_LOCAL_OVERRIDE=1 git push origin local
GUARD_MSG
  exit 1
fi
# Re-emit the stdin we consumed so downstream logic (if any) sees the same lines.
# (Currently downstream CI checks below do not read stdin, but preserve the
# contract for future hook chaining.)
printf '%s' "$LOCAL_STDIN"

echo "Running pre-push checks (CI parity)..."

if ! command -v bats >/dev/null 2>&1; then
  echo "bats is required to run pre-push checks." >&2
  exit 1
fi

if ! command -v uvx >/dev/null 2>&1; then
  echo "uvx is required to run pre-push checks." >&2
  exit 1
fi

# Pick the first python that actually runs. A bare `command -v python3` is not
# enough on Windows, where `python3` resolves to a non-functional Microsoft
# Store App Execution Alias stub; probe each candidate so the broken stub is
# skipped in favour of a working `python`. CI (real python3) matches first.
PY=""
for cand in python3 python; do
  if command -v "$cand" >/dev/null 2>&1 && "$cand" -c "import sys" >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done
if [ -z "$PY" ]; then
  echo "no working python interpreter found on PATH" >&2
  exit 1
fi

# CI job: frontmatter-lint
echo "Checking SKILL.md frontmatter (scripts/lint-frontmatter.sh)..."
bash scripts/lint-frontmatter.sh

# CI job: hangul-check is enforced in .githooks/pre-commit (commit-time gate).

# CI job: bats (Structure Tests) — run the whole tests/ dir, not a single file.
echo "Running bats tests (tests/)..."
bats tests/

# CI job: pytest (Deploy Tests) — run the whole tests/ dir so test_check_hangul.py
# is exercised too, not just test_deploy.py.
echo "Running pytest (tests)..."
uvx --from pytest pytest tests -v
