{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "include-component-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": false,
  "pull-request-title-pattern": "chore: release skills",
  "pull-request-header": "Combined release PR for all skills updated since the last release.",
  "skip-github-release": false,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "refactor",
      "section": "Refactor"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "ci",
      "section": "CI/CD",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Chore",
      "hidden": true
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "style",
      "section": "Style",
      "hidden": true
    }
  ],
  "packages": {
